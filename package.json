{
  "name": "gnosys",
  "version": "5.11.1",
  "description": "Gnosys — Persistent Memory for AI Agents. Sandbox-first runtime, central SQLite brain, federated search, Dream Mode, Web Knowledge Base, Obsidian export.",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./web": {
      "types": "./dist/lib/staticSearch.d.ts",
      "import": "./dist/lib/staticSearch.js"
    }
  },
  "bin": {
    "gnosys": "dist/cli.js",
    "gnosys-mcp": "dist/index.js"
  },
  "scripts": {
    "prebuild": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "tsc",
    "prebuild:publish": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build:publish": "tsc -p tsconfig.publish.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "cli": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "docs:mcp-tools": "node scripts/gen-mcp-tools.mjs --write",
    "docs:cli": "node scripts/gen-cli-docs.mjs --write",
    "postinstall": "node dist/postinstall.js || true",
    "prepublishOnly": "npm run build:publish"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "cli-highlight": "^2.1.11",
    "commander": "^13.1.0",
    "csv-parse": "^6.1.0",
    "dotenv": "^17.3.1",
    "glob": "^13.0.6",
    "gray-matter": "^4.0.3",
    "ink": "^7.0.1",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "marked": "^14.1.4",
    "pdf-parse": "^2.4.5",
    "react": "^19.2.5",
    "turndown": "^7.2.2",
    "ulidx": "^2.4.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.14",
    "@types/turndown": "^5.0.6",
    "@vitest/coverage-v8": "^4.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20.12.0"
  },
  "files": [
    "dist",
    "!dist/test",
    "prompts",
    "README.md",
    "LICENSE",
    "docs/logo.svg"
  ],
  "keywords": [
    "gnosys",
    "memory",
    "llm",
    "mcp",
    "knowledge",
    "persistent-memory",
    "agent",
    "ai",
    "ai-memory",
    "claude",
    "cursor",
    "obsidian",
    "sqlite",
    "semantic-search",
    "hybrid-search",
    "embeddings",
    "chatbot",
    "serverless",
    "knowledge-base",
    "model-context-protocol",
    "agent-memory"
  ],
  "license": "MIT",
  "author": {
    "name": "Proticom",
    "url": "https://proticom.com"
  },
  "contributors": [
    {
      "name": "Edward Tadros",
      "email": "etadros@proticom.com",
      "url": "https://proticom.com"
    }
  ],
  "homepage": "https://gnosys.ai",
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/proticom/gnosys.git"
  },
  "bugs": {
    "url": "https://github.com/proticom/gnosys/issues"
  },
  "optionalDependencies": {
    "@huggingface/transformers": "^4.2.0",
    "better-sqlite3": "^11.7.0"
  },
  "overrides": {
    "prebuild-install": "^7.1.3",
    "node-domexception": "null"
  }
}
