  "license": "MIT",
  "homepage": "https://gnosys.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/proticom/gnosys-mcp"
  },
  "optionalDependencies": {
    "@xenova/transformers": "^2.17.2"
  }
