{
  "name": "gnosys",
  "version": "4.1.3",
  "description": "Gnosys — Persistent Memory for AI Agents. Sandbox-first runtime, central SQLite brain, federated search, Dream Mode, Web Knowledge Base, Obsidian export.",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./web": {
      "types": "./dist/lib/staticSearch.d.ts",
      "import": "./dist/lib/staticSearch.js"
    }
  },
  "bin": {
    "gnosys": "dist/cli.js",
    "gnosys-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "cli": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "commander": "^13.1.0",
    "csv-parse": "^6.1.0",
    "dotenv": "^17.3.1",
    "glob": "^13.0.6",
    "gray-matter": "^4.0.3",
    "turndown": "^7.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/turndown": "^5.0.6",
    "@vitest/coverage-v8": "^4.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "!dist/test",
    "prompts",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "gnosys",
    "memory",
    "llm",
    "mcp",
    "knowledge",
    "persistent-memory",
    "agent",
    "ai",
    "ai-memory",
    "claude",
    "cursor",
    "obsidian",
    "sqlite",
    "semantic-search",
    "hybrid-search",
    "embeddings",
    "chatbot",
    "serverless",
    "knowledge-base"
  ],
  "license": "MIT",
  "author": {
    "name": "Edward Tadros",
    "url": "https://github.com/proticom"
  },
  "homepage": "https://gnosys.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/proticom/gnosys"
  },
  "bugs": {
    "url": "https://github.com/proticom/gnosys/issues"
  },
  "optionalDependencies": {
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^11.7.0"
  },
  "overrides": {
    "prebuild-install": "^7.1.3",
    "node-domexception": "null"
  }
}
